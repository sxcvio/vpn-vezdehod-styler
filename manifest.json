{
  "manifest_version": 3,
  "name": "VPN Vezdehod Styler",
  "description": "7 тем для acc.kompot.sbs",
  "version": "2.0.0",
  "permissions": ["storage"],
  "host_permissions": ["https://acc.kompot.sbs/*"],
  "content_scripts": [
    {
      "matches": ["https://acc.kompot.sbs/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VPN Styler"
  }
}
